APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

AUTH_GUARD=api
JWT_SECRET=
JWT_TTL=10080
JWT_REFRESH_TTL=20160
TASKER_SEED_PASSWORD=TaskerSeed!2026

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: production uses MAIL_MAILER=resend with RESEND_API_KEY set.
# Local dev defaults to "log" — outbound mail is written to storage/logs/laravel.log.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@taskers.rw"
MAIL_FROM_NAME="Taskerz"

# Resend transactional email (resend.com)
RESEND_API_KEY=
# Optional: bounce/complaint webhook signing
RESEND_WEBHOOK_SECRET=

# Mail queue + retry tuning (see config/notifications.php)
MAIL_QUEUE_CONNECTION=
MAIL_QUEUE_NAME=emails
MAIL_QUEUE_TRIES=3

# Comma-separated list of admins who receive operational alerts
# (new task requests, etc.)
ADMIN_NOTIFICATION_EMAILS=

# Public-facing support contact shown in transactional emails
SUPPORT_EMAIL=support@taskers.rw
SUPPORT_PHONE="+250 785 775 280"

# Public web URL used to build links inside emails (password reset, etc.)
FRONTEND_URL=https://taskers.rw

# Verification + password-reset windows (minutes)
PASSWORD_RESET_TTL_MINUTES=60
VERIFICATION_CODE_TTL_MINUTES=30

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
